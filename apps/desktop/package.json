{
  "name": "@broadcasts/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently --kill-others -n server,react,electron -c blue,green,yellow \"node server/server.js\" \"BROWSER=none PORT=3002 react-scripts start\" \"wait-on http://localhost:3002 && electron .\"",
    "build": "react-scripts build && electron-builder",
    "build:react": "react-scripts build",
    "pack": "react-scripts build && electron-builder --dir",
    "start": "react-scripts start",
    "server": "nodemon server/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@broadcasts/chess": "workspace:*",
    "@broadcasts/protocol": "workspace:*",
    "@broadcasts/ui": "workspace:*",
    "@headlessui/react": "^2.2.9",
    "@react-chess/chessground": "^1.3.4",
    "@tailwindcss/forms": "^0.5.3",
    "chess.js": "^1.4.0",
    "chessground": "^9.2.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "uuid": "^13.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.4",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^2.0.15",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.0.23",
    "typescript": "^5.3.0",
    "wait-on": "^9.0.4"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "build": {
    "appId": "com.chesscentre.broadcast",
    "productName": "Chess Broadcast",
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!__tests__/**",
          "!jest.config.js"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.board-games",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game"
    },
    "publish": {
      "provider": "github",
      "owner": "chess-centre",
      "repo": "broadcasts"
    }
  }
}
