# Server Configuration
PORT=8080
CORS_ORIGIN=*

# DGT LiveChess Configuration
# Path to the directory where DGT LiveChess saves PGN files
DGT_BASE_PATH=C:/Users/user/Desktop/Live

# DGT LiveChess WebSocket API URL
DGT_API_URL=ws://127.0.0.1:1982/api/v1.0

# Watch mode: 'files' (recommended) or 'api' (experimental)
DGT_WATCH_MODE=files

# Broadcast Settings
MAX_BOARDS=20
POLL_INTERVAL=1000
DEBUG=false
